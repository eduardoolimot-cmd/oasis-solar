# =========================================
# OASIS SOLAR — variáveis de ambiente
# =========================================
# Copie para .env e ajuste os valores.
# NUNCA commite o .env real.

# Porta do servidor HTTP
PORT=3001

# Ambiente (development | production)
NODE_ENV=development

# Banco de dados
# Dev local (SQLite): file:./dev.db
# Produção (PostgreSQL no Railway): gerado automaticamente como DATABASE_URL
DATABASE_URL="file:./dev.db"

# Segredo do JWT (gere com: openssl rand -base64 32)
JWT_SECRET="troque-este-valor-em-producao-use-string-aleatoria-longa"

# Tempo de expiração do token (formato zeit/ms)
JWT_EXPIRES_IN="7d"

# Origem permitida no CORS (URL do frontend)
# Em produção, troque pelo domínio real do cliente
CORS_ORIGIN="http://localhost:5173"

# Diretório de uploads (relativo ao server/)
UPLOAD_DIR="uploads"

# Limite de tamanho de arquivo (em bytes — 10MB por padrão)
UPLOAD_MAX_BYTES=10485760
